# Tableau Migration Configuration
# Copy this file to .env and fill in your credentials
# IMPORTANT: Add .env to .gitignore (never commit credentials!)

# SOURCE: Tableau Server
TABLEAU_SERVER_URL=https://tableau-server.company.com
TABLEAU_SERVER_SITE=marketing
TABLEAU_SERVER_TOKEN_NAME=your-server-token-name
TABLEAU_SERVER_TOKEN=your-server-token-secret

# DESTINATION: Tableau Cloud
TABLEAU_CLOUD_URL=https://10ax.online.tableau.com
TABLEAU_CLOUD_SITE=production
TABLEAU_CLOUD_TOKEN_NAME=your-cloud-token-name
TABLEAU_CLOUD_TOKEN=your-cloud-token-secret
